{
  "name": "@humanagencyp/linkedin-mcp",
  "version": "1.0.1",
  "description": "LinkedIn MCP server — publish posts, articles, and media via the LinkedIn API",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "linkedin-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --outDir dist --clean",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build",
    "release:patch": "npm version patch && git push --follow-tags",
    "release:minor": "npm version minor && git push --follow-tags",
    "release:major": "npm version major && git push --follow-tags"
  },
  "keywords": [
    "mcp",
    "linkedin",
    "hap",
    "ai-agents"
  ],
  "author": "Andreas Schadauer",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
